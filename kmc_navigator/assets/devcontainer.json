{
      "name": "KMC Navigator (Flutter)",
        "image": "ghcr.io/cirruslabs/flutter:stable",
          "postCreateCommand": "flutter pub get",
            "forwardPorts": [8080],
              "portsAttributes": {
                  "8080": {
                        "label": "Flutter Web Preview",
                              "onAutoForward": "openBrowser"
                                  }
                                    },
                                      "customizations": {
                                          "vscode": {
                                                "extensions": [
                                                        "Dart-Code.dart-code",
                                                                "Dart-Code.flutter"
                                                                      ]
                                                                          }
                                                                            },
                                                                              "remoteUser": "root"
                                                                              }
}